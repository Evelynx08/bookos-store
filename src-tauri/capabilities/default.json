{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions",
  "windows": ["main"],
  "remote": {
    "urls": ["http://localhost/*", "http://localhost:*/*"]
  },
  "permissions": [
    "allow-list-apps",
    "allow-is-installed",
    "allow-pm-info",
    "allow-launch-app",
    "allow-open-release-page",
    "allow-install-pkg-file",
    "allow-uninstall-pkg",
    "allow-download-pkg",
    "allow-detect-system-theme",
    "allow-get-icon",
    "allow-verify-password",
    "allow-cancel-op",
    "allow-progress",
    "core:default",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-set-fullscreen",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-set-title",
    "core:event:default",
    "core:app:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**" },
        { "path": "$HOME/**" },
        { "path": "$CACHE/**" },
        { "path": "$DOWNLOAD/**" }
      ]
    }
  ]
}
