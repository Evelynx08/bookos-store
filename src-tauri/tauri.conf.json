{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "identifier": "com.bookos.store",
  "productName": "Bookos Store",
  "mainBinaryName": "bookos-store",
  "version": "0.4.0",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "targets": ["deb", "rpm"],
    "publisher": "BookOS",
    "category": "Utility",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      }
    }
  }
}
